{
  // Preferred pi packages — installed globally via `install.sh`
  "packages": [
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:pi-intercom",
    "npm:@latentminds/pi-quotas",
    "npm:pi-web-access",
    "npm:@trevonistrevon/pi-loop",
    // Context-pruning trial (token cost reduction, see wip/2026-07-09-token-cost-investigation.md)
    "npm:pi-condense",
    "npm:pi-context-usage",
    "npm:pi-cache-graph"
  ],

  // Settings merged into ~/.pi/agent/settings.json by lib/install_pi_settings.sh.
  // Only the top-level keys declared here are managed (uninstall removes them).
  "settings": {
    // Make git non-interactive for the agent's bash tool only (not Mihai's
    // shell): GIT_EDITOR=true silences `rebase --continue` / `merge --continue`
    // commit-message prompts; GIT_SEQUENCE_EDITOR=: makes `rebase -i` accept the
    // todo without opening an editor. Prepended to every pi bash command via
    // the bash tool's commandPrefix, so it never touches interactive terminals.
    "shellCommandPrefix": "export GIT_EDITOR=true GIT_SEQUENCE_EDITOR=:",

    // pi-condense: prune once per task batch (cache-friendly), summarize with
    // cheap haiku, force a flush at 80% of the context window so long-lived
    // sessions stay under the 200K long-context premium.
    "contextPrune": {
      "enabled": true,
      "pruneOn": "agent-message",
      "summarizerModel": "anthropic/claude-haiku-4-5",
      "summarizerThinking": "off",
      "autoBudgetThreshold": 0.8
    }
  }
}
